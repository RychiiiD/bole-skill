{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--user-data-dir",
        ".claude/browser_profile",
        "--viewport-size",
        "1280x720",
        "--shared-browser-context",
        "--browser",
        "chrome"
      ]
    }
  }
}
